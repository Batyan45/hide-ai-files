{
  "name": "hide-ai-files",
  "displayName": "Hide AI Files",
  "description": "One status bar button to instantly hide or show all AI-specific files and folders (Cursor, Claude, Copilot, Windsurf, Trellis, and more) across your projects.",
  "version": "1.0.0",
  "publisher": "batyan-soft",
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "cursor",
    "claude",
    "copilot",
    "hide",
    "files",
    "explorer",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Batyan45/hide-ai-files.git"
  },
  "bugs": {
    "url": "https://github.com/Batyan45/hide-ai-files/issues"
  },
  "contributes": {
    "configuration": {
      "title": "Hide AI Files",
      "properties": {
        "hide-ai-files.patterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.cursor",
            "**/.cursorrules",
            "**/.cursorignore",
            "**/.claude",
            "**/CLAUDE.md",
            "**/CLAUDE.local.md",
            "**/.windsurf",
            "**/.windsurfrules",
            "**/.trellis",
            "**/.aider*",
            "**/.continue",
            "**/.codeium",
            "**/.tabnine",
            "**/.cody",
            "**/.sourcegraph",
            "**/.roo",
            "**/.roomodes",
            "**/.cline",
            "**/.clinerules",
            "**/.kilocode",
            "**/.codex",
            "**/.gemini",
            "**/GEMINI.md",
            "**/.amazonq",
            "**/.augment",
            "**/.augmentignore",
            "**/.qodo",
            "**/.pearai",
            "**/.bolt",
            "**/.specstory",
            "**/.taskmaster",
            "**/.devin",
            "**/.junie",
            "**/.opencode",
            "**/.openhands",
            "**/.ai-memory.git",
            "**/.codegraph",
            "**/.github/copilot-instructions.md",
            "**/.github/instructions",
            "**/.github/prompts",
            "**/.github/chatmodes",
            "**/AGENTS.md",
            "**/.agent",
            "**/.agents",
            "**/mcp.json",
            "**/.mcp.json",
            "**/repomix-output.*"
          ],
          "description": "Glob patterns (matched anywhere in the tree via the `**/` prefix) added to `files.exclude` when AI files are hidden. Customize this to add or remove the files and folders the toggle controls."
        },
        "hide-ai-files.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the AI files toggle button in the status bar."
        },
        "hide-ai-files.showLabel": {
          "type": "boolean",
          "default": false,
          "description": "Show the \"AI Files\" text label next to the status bar icon. When disabled, only the icon is shown."
        }
      }
    },
    "commands": [
      {
        "command": "hide-ai-files.toggle",
        "title": "Toggle AI Files Visibility",
        "icon": "$(eye)"
      },
      {
        "command": "hide-ai-files.hide",
        "title": "Hide AI Files"
      },
      {
        "command": "hide-ai-files.show",
        "title": "Show AI Files"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "build-vsix": "npm run package && vsce package",
    "version": "npm version --no-git-tag-version"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.24.0",
    "eslint": "^8.56.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  }
}
